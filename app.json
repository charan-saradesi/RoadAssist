{
  "expo": {
    "name": "mymobileAPP",
    "slug": "mymobileAPP",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "mymobileapp",
    "userInterfaceStyle": "automatic",
    "extra": {
      "API_URL": "http://192.168.31.34:8000",
      "router": {
        "origin": "https://roadassist.com"
      },
      "eas": {
        "projectId": "b3c6432d-b922-43e8-9acb-8ca395f54a5e"
      }
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.mymobileAPP",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find nearby providers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to find nearby providers.",
        "NSLocationAlwaysUsageDescription": "We need your location to find nearby providers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.mymobileAPP",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://roadassist.com"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "We need your location to find nearby providers.",
          "locationAlwaysAndWhenInUsePermission": "We need your location to find nearby providers.",
          "locationAlwaysPermission": "We need your location to find nearby providers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "charanvip"
  }
}
